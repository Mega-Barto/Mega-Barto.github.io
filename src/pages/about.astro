---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Section from '../components/astro/Section.astro';
import SiteFooter from '../components/astro/SiteFooter.astro';
import SiteHeader from '../components/astro/SiteHeader.astro';
import { t } from '../i18n/t';
import BaseLayout from '../layouts/BaseLayout.astro';

const profileImageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/ProfileImages/*.{jpg,jpeg,png,webp}',
  { eager: true },
);
const profileImages = Object.values(profileImageModules).map((mod) => mod.default);

const title = `${t('header.navigation.autobiography')} — ${t('personal.displayName')}`;
const description = t('autobiography.introduction');
---

<BaseLayout title={title} description={description}>
  <div class="app">
    <SiteHeader />
    <main class="main-content page-detail">
      <Section id="autobiography" titleKey="header.navigation.autobiography">
        <div class="about-grid">
          <aside class="about-sidebar">
            <div class="about-image-stack">
              {
                profileImages.map((src, i) => (
                  <Image
                    src={src}
                    alt={t('personal.displayName')}
                    class:list={['about-avatar', 'about-avatar-slot', { 'is-active': i === 0 }]}
                    widths={[280, 420, 560]}
                    sizes="(max-width: 900px) 260px, 280px"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                    fetchpriority={i === 0 ? 'high' : undefined}
                    aria-hidden={i !== 0}
                    data-about-profile=""
                  />
                ))
              }
            </div>
            <script is:inline>
              (function () {
                var slots = document.querySelectorAll('[data-about-profile]');
                if (slots.length <= 1) return;
                var idx = Math.floor(Math.random() * slots.length);
                slots.forEach(function (el, i) {
                  var on = i === idx;
                  el.classList.toggle('is-active', on);
                  el.setAttribute('aria-hidden', on ? 'false' : 'true');
                  if (on) el.setAttribute('loading', 'eager');
                });
              })();
            </script>
            <div class="about-contact">
              <h4 data-i18n-key="about.contactTitle">{t('about.contactTitle')}</h4>
              <p><a href="mailto:personal.jperez@gmail.com">Email</a></p>
              <p><a href="https://github.com/Mega-Barto" target="_blank" rel="noopener noreferrer">GitHub</a></p>
              <p><a href="https://linkedin.com/in/mega-barto" target="_blank" rel="noopener noreferrer">LinkedIn</a></p>
            </div>

            <div class="about-skills-block">
              <h4 data-i18n-key="about.skillsTitle">{t('about.skillsTitle')}</h4>
              <ul class="skills-list">
                {t('about.skills').split(',').map((s) => <li class="skill-pill">{s.trim()}</li>)}
              </ul>
            </div>
          </aside>

          <article class="about-prose">
            <h2 data-i18n-key="about.bioTitle">{t('about.bioTitle')}</h2>
            <p class="about-lead" data-i18n-key="about.bioLead">{t('about.bioLead')}</p>
            <p data-i18n-key="about.bioText">{t('about.bioText')}</p>

            <h3 data-i18n-key="about.timelineTitle">{t('about.timelineTitle')}</h3>
            <p data-i18n-key="about.timelineLead">{t('about.timelineLead')}</p>

            <p class="call-to-action" data-i18n-key="about.contactCTA">{t('about.contactCTA')}</p>
          </article>
        </div>
      </Section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .about-sidebar {
    order: 1;
    text-align: center;
    position: sticky;
    top: 1.5rem;
  }

  .about-prose {
    order: 2;
    min-width: 0;
  }

  .about-avatar {
    width: 220px;
    height: 220px;
    object-fit: cover;
    border-radius: 12px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.35);
    margin-bottom: 1rem;
  }

  .about-image-stack {
    position: relative;
    width: 220px;
    height: 220px;
    margin: 0 auto 1rem;
  }

  .about-image-stack .about-avatar-slot:not(.is-active) {
    display: none;
  }

  .about-image-stack .about-avatar-slot.is-active {
    display: block;
  }

  .about-contact h4 { margin: 0 0 0.25rem 0; }

  .about-skills-block {
    margin-top: 1.25rem;
  }

  .skills-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
    margin: 0.75rem auto 1rem;
    max-width: 240px;
    justify-items: center;
  }

  .skill-pill {
    background: var(--color-secondary-800);
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    font-size: 0.9rem;
    text-align: center;
    width: 100%;
  }

  .call-to-action { margin-top:1.5rem; font-weight:600 }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-sidebar {
      position: static;
      order: 1;
    }

    .about-prose {
      order: 2;
    }

    .skills-list {
      max-width: 280px;
    }
  }

  .about-prose {
    max-width: 760px;
    margin: 0 auto;
    color: var(--color-text-inverse);
    text-align: justify;
  }

  .about-prose p {
    margin: 0 0 1.25rem;
    line-height: 1.75;
    font-size: clamp(1rem, 1.8vw, 1.1rem);
  }

  .about-prose p:last-child {
    margin-bottom: 0;
  }

  .about-lead {
    color: var(--color-secondary-300);
    font-style: italic;
    margin-bottom: 2rem !important;
  }
</style>
