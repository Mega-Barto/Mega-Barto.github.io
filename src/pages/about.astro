---
import SiteFooter from '../components/astro/SiteFooter.astro';
import SiteHeader from '../components/astro/SiteHeader.astro';
import { t } from '../i18n/t';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../components/sections/AutobiographySection/AutobiographySection.css';

const title = `${t('header.navigation.autobiography')} — ${t('personal.displayName')}`;
const description = t('autobiography.introduction');
---

<BaseLayout title={title} description={description}>
  <div class="app">
    <SiteHeader />
    <main class="main-content page-detail">
      <section id="autobiography" class="autobiography-section">
        <div class="container">
          <h1 class="section-title" data-i18n-key="header.navigation.autobiography">
            {t('header.navigation.autobiography')}
          </h1>
          <p class="section-lead" data-i18n-key="about.detailLead">
            {t('about.detailLead')}
          </p>
          <div class="autobiography-content">
            <div class="autobiography-layout">
              <div class="text-block text-intro">
                <p data-i18n-key="autobiography.introduction">{t('autobiography.introduction')}</p>
              </div>
              <div class="text-block text-background">
                <p data-i18n-key="autobiography.background">{t('autobiography.background')}</p>
              </div>
              <div class="text-block text-current">
                <p data-i18n-key="autobiography.current">{t('autobiography.current')}</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .section-lead {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-secondary);
  }
</style>
