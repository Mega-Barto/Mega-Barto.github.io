---
import SiteFooter from '../../components/astro/SiteFooter.astro';
import SiteHeader from '../../components/astro/SiteHeader.astro';
import EventsSectionIsland from '../../components/islands/EventsSectionIsland';
import { t } from '../../i18n/t';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title={`${t('events.name')} — ${t('personal.displayName')}`} description={t('events.description')}>
  <div class="app">
    <SiteHeader />
    <main class="main-content page-detail">
      <h1 class="page-title" data-i18n-key="events.name">{t('events.name')}</h1>
      <EventsSectionIsland client:load variant="full" />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .page-title {
    color: var(--color-text-inverse);
    margin-bottom: 1rem;
  }
</style>
