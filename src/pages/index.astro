---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Carousel from '../components/astro/Carousel.astro';
import SiteFooter from '../components/astro/SiteFooter.astro';
import SiteHeader from '../components/astro/SiteHeader.astro';
import CertificatesSection from '../components/astro/sections/CertificatesSection.astro';
import EventsSection from '../components/astro/sections/EventsSection.astro';
import ProjectsSection from '../components/astro/sections/ProjectsSection.astro';
import WorkExperienceSection from '../components/astro/sections/WorkExperienceSection.astro';
import { t } from '../i18n/t';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/baseUrl';

import '../components/sections/AutobiographySection/AutobiographySection.css';

const title = `${t('personal.displayName')} — ${t('personal.domain')}`;
const description = t('personal.description');

const profileImageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/ProfileImages/*.{jpg,jpeg,png,webp}',
  { eager: true },
);
/** Todas las variantes se optimizan en build; la elección aleatoria ocurre en el cliente (cada refresh). */
const profileImages = Object.values(profileImageModules).map((mod) => mod.default);
---

<BaseLayout title={title} description={description}>
  <div class="app">
    <SiteHeader />
    <main class="main-content">
      <section class="hero-section">
        <div class="hero-content">
          <div class="hero-image hero-image-stack">
            {
              profileImages.map((src, i) => (
                <Image
                  src={src}
                  alt={t('personal.displayName')}
                  class:list={['hero-profile-image', 'hero-profile-slot', { 'is-active': i === 0 }]}
                  widths={[320, 480, 640]}
                  sizes="(max-width: 768px) 240px, 280px"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  fetchpriority={i === 0 ? 'high' : undefined}
                  aria-hidden={i !== 0}
                  data-hero-profile=""
                />
              ))
            }
          </div>
          <script is:inline>
            (function () {
              var slots = document.querySelectorAll('[data-hero-profile]');
              if (slots.length <= 1) return;
              var idx = Math.floor(Math.random() * slots.length);
              slots.forEach(function (el, i) {
                var on = i === idx;
                el.classList.toggle('is-active', on);
                el.setAttribute('aria-hidden', on ? 'false' : 'true');
                if (on) el.setAttribute('loading', 'eager');
              });
            })();
          </script>
          <h1 data-i18n-key="home.hero.welcome">{t('home.hero.welcome')}</h1>
          <p data-i18n-key="personal.description">{t('personal.description')}</p>
        </div>
      </section>
      <section id="autobiography" class="autobiography-section">
        <div class="container">
          <h2 class="section-title" data-i18n-key="header.navigation.autobiography">
            {t('header.navigation.autobiography')}
          </h2>
          <div class="autobiography-content">
            <div class="autobiography-layout">
              <div class="text-block text-intro">
                <p data-i18n-key="autobiography.introduction">{t('autobiography.introduction')}</p>
              </div>
              <div class="text-block text-background">
                <p data-i18n-key="autobiography.background">{t('autobiography.background')}</p>
              </div>
              <div class="text-block text-current">
                <p data-i18n-key="autobiography.current">{t('autobiography.current')}</p>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="carousel-section-wrap">
        <h2 class="carousel-section-title" data-i18n-key="carousel.title">{t('carousel.title')}</h2>
        <Carousel />
      </section>
      <WorkExperienceSection variant="summary" viewAllHref={withBase('/work-experience/')} />
      <ProjectsSection variant="summary" viewAllHref={withBase('/projects/')} />
      <CertificatesSection variant="summary" viewAllHref={withBase('/certificates/')} />
      <EventsSection variant="summary" viewAllHref={withBase('/events/')} />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .hero-image-stack {
    position: relative;
    width: 200px;
    height: 200px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-image-stack .hero-profile-slot:not(.is-active) {
    display: none;
  }

  .hero-image-stack .hero-profile-slot.is-active {
    display: block;
  }

  .carousel-section-wrap {
    width: 100%;
  }
  .carousel-section-title {
    text-align: center;
    color: var(--color-text-inverse);
    margin: 0 0 1rem;
    padding-top: 1.5rem;
  }
</style>
