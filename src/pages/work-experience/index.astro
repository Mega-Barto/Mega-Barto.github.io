---
import SiteFooter from '../../components/astro/SiteFooter.astro';
import SiteHeader from '../../components/astro/SiteHeader.astro';
import WorkExperienceSectionIsland from '../../components/islands/WorkExperienceSectionIsland';
import { t } from '../../i18n/t';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title={`${t('header.navigation.workExperience')} — ${t('personal.displayName')}`}
  description={t('workExperience.descriptions.taejf')}
>
  <div class="app">
    <SiteHeader />
    <main class="main-content page-detail">
      <h1 class="page-title" data-i18n-key="header.navigation.workExperience">
        {t('header.navigation.workExperience')}
      </h1>
      <WorkExperienceSectionIsland client:load variant="full" />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .page-title {
    color: var(--color-text-inverse);
    margin-bottom: 1rem;
  }
</style>
