---
import SiteFooter from '../../components/astro/SiteFooter.astro';
import SiteHeader from '../../components/astro/SiteHeader.astro';
import CertificatesSection from '../../components/astro/sections/CertificatesSection.astro';
import { t } from '../../i18n/t';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title={`${t('header.navigation.certificates')} — ${t('personal.displayName')}`}
  description={t('certificates.automation.title')}
>
  <div class="app">
    <SiteHeader />
    <main class="main-content page-detail">
      <h1 class="page-title" data-i18n-key="header.navigation.certificates">
        {t('header.navigation.certificates')}
      </h1>
      <CertificatesSection variant="full" />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .page-title {
    color: var(--color-text-inverse);
    margin-bottom: 1rem;
  }
</style>
