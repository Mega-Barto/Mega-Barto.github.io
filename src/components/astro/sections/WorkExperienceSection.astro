---
import { sortWorksByRecency, WORK_DEFS } from '../../../content/work-experiences';
import { t } from '../../../i18n/t';
import Section from '../Section.astro';

import '../../sections/WorkExperienceSection/WorkExperienceSection.css';

interface Props {
  variant: 'summary' | 'full';
  viewAllHref?: string;
}

const { variant, viewAllHref } = Astro.props;
const isSummary = variant === 'summary';
const sorted = sortWorksByRecency(WORK_DEFS);
const defs = isSummary ? sorted.slice(0, 3) : sorted;

function monthsBetween(isoStart?: string, isoEnd?: string) {
  if (!isoStart) return null;
  try {
    const start = new Date(isoStart);
    const end = isoEnd ? new Date(isoEnd) : new Date();
    let months =
      (end.getFullYear() - start.getFullYear()) * 12 + (end.getMonth() - start.getMonth());
    if (end.getDate() < start.getDate()) months -= 1;
    if (months < 0) months = 0;
    return String(months);
  } catch {
    return null;
  }
}
---

<Section id="work-experience" titleKey="header.navigation.workExperience">
  <div class="work-experience-grid">
    {
      defs.map((work) => (
        <div class="work-card">
          <div class="work-header">
            <h3 class="work-title">
              <a
                href={work.href}
                target="_blank"
                rel="noopener noreferrer"
                class="work-link"
              >
                <span data-i18n-key={work.labelKey}>{t(work.labelKey)}</span>
              </a>
            </h3>
            {work.actual && (
              <span class="work-current-badge" data-i18n-key="workExperience.current">
                {t('workExperience.current')}
              </span>
            )}
            {work.badgeKey && (
              <span class="work-badge" data-i18n-key={work.badgeKey}>
                {t(work.badgeKey)}
              </span>
            )}
          </div>
          <div class="work-info">
            <span class="work-time" data-i18n-key={work.timeKey}>
              {t(work.timeKey)}
            </span>
            {
              (work.durationKey || work.startDate) && (
                <span class="work-duration">
                  <span data-i18n-key="workExperience.duration">{t('workExperience.duration')}</span>
                  {': '}
                  {work.startDate ? (
                    (() => {
                      const months = monthsBetween(work.startDate, work.endDate);
                      if (months !== null) {
                        return <span data-i18n-key="workExperience.durationMonths" data-i18n-args={JSON.stringify({ months })}>{t('workExperience.durationMonths', undefined, { months })}</span>;
                      }
                      return <span>-</span>;
                    })()
                  ) : (
                    <span data-i18n-key={work.durationKey}>{t(work.durationKey ?? '')}</span>
                  )}
                </span>
              )
            }
          </div>
          {!isSummary && (
            <div class="work-description-container">
              <p
                class="work-description"
                data-i18n-key={`workExperience.descriptions.${work.id}`}
              >
                {t(`workExperience.descriptions.${work.id}`)}
              </p>
              <button
                class="work-read-more"
                data-work-id={work.id}
                data-i18n-key="workExperience.readMore"
              >
                {t('workExperience.readMore')}
              </button>
            </div>
          )}
        </div>
      ))
    }
  </div>
  {
    variant === 'summary' && viewAllHref && (
      <p class="section-view-all">
        <a href={viewAllHref} class="view-all-link" data-i18n-key="common.viewAll">
          {t('common.viewAll')}
        </a>
      </p>
    )
  }
</Section>

<!-- Work Experience Modal -->
{!isSummary && (
  <div class="work-modal-overlay" id="work-modal-overlay">
    <div class="work-modal">
      <div class="work-modal-header">
        <div class="work-modal-title-row">
          <h3 class="work-modal-title" id="work-modal-title"></h3>
          <div class="work-modal-badges" id="work-modal-badges"></div>
        </div>
        <button class="work-modal-close" id="work-modal-close" aria-label={t('workExperience.close')}>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="work-modal-body">
        <div class="work-modal-info" id="work-modal-info">
          <span class="work-modal-time" id="work-modal-time"></span>
          <span class="work-modal-duration" id="work-modal-duration"></span>
        </div>
        <p class="work-modal-description" id="work-modal-description"></p>
        <a class="work-modal-link" id="work-modal-link" href="#" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
          <span data-i18n-key="workExperience.visitWebsite">{t('workExperience.visitWebsite')}</span>
        </a>
      </div>
    </div>
  </div>
)}

{!isSummary && (
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const overlay = document.getElementById('work-modal-overlay');
      const modalTitle = document.getElementById('work-modal-title');
      const modalBadges = document.getElementById('work-modal-badges');
      const modalTime = document.getElementById('work-modal-time');
      const modalDuration = document.getElementById('work-modal-duration');
      const modalDescription = document.getElementById('work-modal-description');
      const modalLink = document.getElementById('work-modal-link') as HTMLAnchorElement | null;
      const closeBtn = document.getElementById('work-modal-close');
      const readMoreBtns = document.querySelectorAll('.work-read-more');

      if (!overlay || !modalTitle || !modalDescription || !closeBtn) return;

      readMoreBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const card = btn.closest('.work-card');
          if (!card) return;
          
          const titleEl = card.querySelector('.work-title span');
          const linkEl = card.querySelector('.work-link');
          const descEl = card.querySelector('.work-description');
          const timeEl = card.querySelector('.work-time');
          const durationEl = card.querySelector('.work-duration');
          const currentBadge = card.querySelector('.work-current-badge');
          const otherBadge = card.querySelector('.work-badge');
          
          if (titleEl && descEl) {
            modalTitle.textContent = titleEl.textContent;
            modalDescription.textContent = descEl.textContent;
            
            if (modalTime && timeEl) {
              modalTime.textContent = timeEl.textContent;
            }
            
            if (modalDuration && durationEl) {
              modalDuration.textContent = durationEl.textContent;
            }
            
            if (modalLink && linkEl) {
              modalLink.href = (linkEl as HTMLAnchorElement).href;
            }
            
            if (modalBadges) {
              modalBadges.innerHTML = '';
              if (currentBadge) {
                const badge = currentBadge.cloneNode(true);
                modalBadges.appendChild(badge);
              }
              if (otherBadge) {
                const badge = otherBadge.cloneNode(true);
                modalBadges.appendChild(badge);
              }
            }
            
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';
          }
        });
      });

      const closeModal = () => {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      };

      closeBtn.addEventListener('click', closeModal);
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeModal();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay.classList.contains('active')) {
          closeModal();
        }
      });
    });
  </script>
)}
