---
import { PROJECT_DEFS } from '../../content/projects';
import type { ProjectStatus } from '../../content/types';
import { t } from '../../i18n/t';

const ALL_STATUSES: ProjectStatus[] = ['completed', 'in-progress', 'planned'];

const techSet = new Set<string>();
for (const p of PROJECT_DEFS) for (const tech of p.technologies) techSet.add(tech);
const techOptions = [...techSet].sort();
---

<div class="projects-filters" data-projects-filters>
  <label>
    <span data-i18n-key="projects.filter.status">{t('projects.filter.status')}</span>
    <select data-filter-status aria-label="status">
      <option value="all" data-i18n-key="projects.filter.all">{t('projects.filter.all')}</option>
      {
        ALL_STATUSES.map((st) => (
          <option value={st} data-i18n-key={`projects.status.${st}`}>
            {t(`projects.status.${st}`)}
          </option>
        ))
      }
    </select>
  </label>
  <label>
    <span data-i18n-key="projects.filter.technology">{t('projects.filter.technology')}</span>
    <select data-filter-tech aria-label="technology">
      <option value="" data-i18n-key="projects.filter.all">{t('projects.filter.all')}</option>
      {techOptions.map((tech) => <option value={tech}>{tech}</option>)}
    </select>
  </label>
</div>

<script>
  const apply = () => {
    const root = document.querySelector<HTMLElement>('[data-projects-filters]');
    if (!root) return;
    const statusSelect = root.querySelector<HTMLSelectElement>('[data-filter-status]');
    const techSelect = root.querySelector<HTMLSelectElement>('[data-filter-tech]');
    if (!statusSelect || !techSelect) return;
    const status = statusSelect.value;
    const tech = techSelect.value;
    for (const card of document.querySelectorAll<HTMLElement>('.project-card[data-status]')) {
      const cardStatus = card.dataset.status ?? '';
      const cardTech = (card.dataset.tech ?? '').split(',');
      const matchStatus = status === 'all' || cardStatus === status;
      const matchTech = tech === '' || cardTech.includes(tech);
      card.hidden = !(matchStatus && matchTech);
    }
  };

  const bind = () => {
    const root = document.querySelector<HTMLElement>('[data-projects-filters]');
    if (!root || root.dataset.bound === 'true') return;
    root.dataset.bound = 'true';
    for (const sel of root.querySelectorAll<HTMLSelectElement>('select')) {
      sel.addEventListener('change', apply);
    }
    apply();
  };

  bind();
  document.addEventListener('DOMContentLoaded', bind);
</script>
