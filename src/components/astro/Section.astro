---
import { t } from '../../i18n/t';

interface Props {
  id: string;
  titleKey: string;
  class?: string;
}

const { id, titleKey, class: className = '' } = Astro.props;
---

<section id={id} class={`page-section ${className}`.trim()}>
  <div class="page-section-inner">
    <h2 class="section-title" data-i18n-key={titleKey}>{t(titleKey)}</h2>
    <slot />
  </div>
</section>
