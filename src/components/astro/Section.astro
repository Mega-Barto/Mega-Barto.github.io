---
interface Props {
  id: string;
  titleKey: string;
  class?: string;
}

const { id, titleKey, class: className = '' } = Astro.props;
import { t } from '../../i18n/t';
---

<section id={id} class={`collapsible-section ${className}`.trim()}>
  <div class="container">
    <div class="section-header-wrapper static">
      <h2 class="section-title" data-i18n-key={titleKey}>{t(titleKey)}</h2>
    </div>
    <div class="collapsible-content expanded">
      <slot />
    </div>
  </div>
</section>
